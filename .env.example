# SMTP Configuration (used for sending enquiry and booking emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Admin email where enquiries and bookings will be sent
ADMIN_EMAIL=admin@example.com

# Optional port for the local API server (defaults to 3001)
API_PORT=3001

# Public contact email used for mailto buttons (frontend)
# Note: this project uses Vite; values are injected client-side via Vite config.
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com

# If you use the Gemini integration in this project
GEMINI_API_KEY=your_gemini_api_key

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ── Supabase (required for admin panel and public data) ──────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Pooler connection string (for direct DB access if needed)
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:6543/postgres
